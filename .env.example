# ============================================
# 本地 AI 助理配置模板
# 复制此文件为 .env 并填写您的配置
# ============================================

# --------------------------------------------
# 本地 AI 配置
# --------------------------------------------
# 本地 AI 是否启用
LOCAL_ENABLED=true

# 本地 API 端点 (llama.cpp 服务地址)
LOCAL_API_URL=http://localhost:8080/completion

# 最大上下文长度 (token 总数限制: system + memory + user + output)
LOCAL_MAX_CONTEXT=8192

# 温度参数 (0.0-1.0, 越低越确定)
LOCAL_TEMPERATURE=0.7

# 最大输出 token 数
LOCAL_MAX_OUTPUT_TOKENS=3000

# --------------------------------------------
# 云端 AI 配置
# --------------------------------------------
# 是否启用云端 AI
CLOUD_ENABLED=true

# 云端提供商: openai | gemini | glm
CLOUD_PROVIDER=glm

# 云端最大上下文长度
CLOUD_MAX_CONTEXT=100000

# 云端最大检索结果数
CLOUD_MAX_RETRIEVE_RESULTS=20

# --------------------------------------------
# OpenAI 配置 (当 CLOUD_PROVIDER=openai 时生效)
# --------------------------------------------
# OpenAI API 密钥 (以 sk- 开头)
OPENAI_API_KEY=sk-your-openai-api-key-here

# 模型名称
OPENAI_MODEL=gpt-4o-mini

# 自定义 API 端点 (可选，用于第三方兼容服务)
# OPENAI_BASE_URL=https://api.openai.com/v1

# --------------------------------------------
# Gemini 配置 (当 CLOUD_PROVIDER=gemini 时生效)
# --------------------------------------------
# Gemini API 密钥
GEMINI_API_KEY=your-gemini-api-key-here

# 模型名称
GEMINI_MODEL=gemini-2.5-flash

# 自定义 API 端点 (可选)
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/

# --------------------------------------------
# GLM (智谱AI) 配置 (当 CLOUD_PROVIDER=glm 时生效)
# --------------------------------------------
# 获取API Key: https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key-here

# 模型名称
GLM_MODEL=glm-4-flash

# API 端点
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --------------------------------------------
# 检索配置
# --------------------------------------------
# 最大检索结果数
MAX_RETRIEVE_RESULTS=5

# 相似度阈值 (0.0-1.0)
SIMILARITY_THRESHOLD=0.90

# L1 最小结果数
L1_MIN_RESULTS=2

# L2 降低阈值 (当 L2 结果不足时使用)
L2_LOWER_THRESHOLD=0.80

# 云端专用检索阈值
CLOUD_L1_THRESHOLD=0.85
CLOUD_L2_THRESHOLD=0.75
CLOUD_L3_THRESHOLD=0.70

# 本地压缩专用检索阈值
LOCAL_L1_THRESHOLD=0.90
LOCAL_L2_THRESHOLD=0.80
LOCAL_L3_THRESHOLD=0.75

# --------------------------------------------
# 上下文构建配置
# --------------------------------------------
# 最大记忆 token 数 (用于云端模式)
MAX_MEMORY_TOKENS=5000

# 系统提示预留 token 数
SYSTEM_PROMPT_RESERVE=200

# --------------------------------------------
# 记忆流动配置
# --------------------------------------------
# 冷却时间 (小时) - 防止记忆频繁往返 L2/L3
MEMORY_FLOW_COOLDOWN_HOURS=24

# L2 迁移阈值乘数 (权重低于此值将迁移到 L3)
L2_MOVE_THRESHOLD_MULTIPLIER=2.0

# L3 提升权重阈值 (权重高于此值将回流到 L2)
L3_PROMOTION_WEIGHT_THRESHOLD=0.8

# 最大 L2→L3 批次大小
MAX_L2_TO_L3_BATCH=20

# 最大 L3→L2 批次大小
MAX_L3_TO_L2_BATCH=10

# --------------------------------------------
# 权重衰减配置
# --------------------------------------------
# 衰减批次大小
DECAY_BATCH_SIZE=1000

# 权重衰减率 (每次衰减乘以该值)
MEMORY_WEIGHT_DECAY=0.95

# 最小权重阈值 (低于此值可能被遗忘)
MEMORY_MIN_WEIGHT=0.3

# 最大权重
MEMORY_MAX_WEIGHT=5.0

# 访问时权重提升倍数
MEMORY_WEIGHT_BOOST=1.2

# 遗忘天数 (超过此天数未访问将被遗忘)
MEMORY_DECAY_DAYS=30

# --------------------------------------------
# 异步处理配置
# --------------------------------------------
# 去重间隔 (秒)
MEMORY_DEDUP_INTERVAL=300

# 压缩间隔 (秒)
MEMORY_COMPRESSION_INTERVAL=600

# 遗忘间隔 (秒)
MEMORY_FORGET_INTERVAL=3600

# 刷新间隔 (秒)
MEMORY_FLUSH_INTERVAL=30

# 缓冲区最大年龄 (秒)
MEMORY_MAX_BUFFER_AGE=60

# 批量更新大小
BATCH_UPDATE_SIZE=5

# 最大待压缩数
MAX_PENDING_COMPRESSIONS=50

# 压缩器检查间隔 (秒)
COMPRESSOR_CHECK_INTERVAL=300

# 压缩器失败阈值
COMPRESSOR_FAILURE_THRESHOLD=5

# 最大队列大小
MAX_QUEUE_SIZE=1000

# 队列满时的动作 (drop_oldest | reject)
QUEUE_FULL_ACTION=drop_oldest

# LLM 超时 (秒)
LLM_TIMEOUT=30

# 断路器阈值
CIRCUIT_BREAKER_THRESHOLD=5

# 断路器重置超时 (秒)
CIRCUIT_BREAKER_RESET_TIMEOUT=300

# --------------------------------------------
# 压缩配置
# --------------------------------------------
# 最小压缩长度 (低于此长度不压缩)
COMPRESSION_MIN_LENGTH=100

# 目标压缩比 (0.0-1.0)
COMPRESSION_TARGET_RATIO=0.6

# 最大分段长度
COMPRESSION_MAX_SEGMENT_LENGTH=2000

# 是否启用降级压缩
COMPRESSION_FALLBACK_ENABLED=true

# --------------------------------------------
# 隐私与安全配置
# --------------------------------------------
# 敏感信息过滤 (发送云端前脱敏)
SENSITIVE_FILTER_ENABLED=true

# 本地数据加密 (默认关闭，影响性能)
LOCAL_ENCRYPTION_ENABLED=false

# 排除关键词 (包含这些词的内容不过滤，逗号分隔)
PRIVACY_EXCLUDED_KEYWORDS=

# 记录敏感信息检测日志
LOG_SENSITIVE_DETECTION=false

# --------------------------------------------
# 过滤配置
# --------------------------------------------
# 废话过滤是否启用
NONSENSE_FILTER_ENABLED=true

# 废话库路径
NONSENSE_DB_PATH=nonsense_library.json

# --------------------------------------------
# 高密度内容配置
# --------------------------------------------
# 高密度内容模式 (正则表达式)
HIGH_DENSITY_PATTERNS=流程图|时序图|架构图|状态机|数据流|ER图|类图|部署图|网络拓扑|API接口|数据库设计|系统设计|技术方案

# 保留比例 (1.0 = 完全不压缩)
HIGH_DENSITY_PRESERVE_RATIO=1.0

# --------------------------------------------
# 向量存储配置
# --------------------------------------------
# ONNX 模型路径
ONNX_MODEL_PATH=models/bge_onnx_model

# 嵌入维度
EMBEDDING_DIMENSION=512

# ChromaDB 持久化目录
CHROMA_PERSIST_DIR=chroma_db

# ChromaDB 集合名称
CHROMA_COLLECTION_NAME=memories

# --------------------------------------------
# SQLite 配置
# --------------------------------------------
# 是否启用 SQLite 存储
SQLITE_ENABLED=true

# 数据库路径
SQLITE_DB_PATH=memory.db

# 最大连接池大小
SQLITE_MAX_POOL_SIZE=10

# 连接超时 (秒)
SQLITE_CONNECTION_TIMEOUT=3600

# 清理间隔 (秒)
SQLITE_CLEANUP_INTERVAL=300

# 忙碌超时 (毫秒)
SQLITE_BUSY_TIMEOUT=30000

# 缓存大小 (页数，负值表示 KB)
SQLITE_CACHE_SIZE=-64000
